{
  "manifest_version": 3,
  "name": "Botcake 数据助手",
  "version": "1.0.0",
  "permissions": ["storage", "tabs", "webNavigation"],
  "host_permissions": ["https://botcake.io/*"],
  "action": {
    "default_title": "打开 Botcake 看板"
  },
  "background": {
    "service_worker": "assets/background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["https://botcake.io/*"],
      "js": ["assets/content.js"],
      "run_at": "document_start"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["assets/*"],
      "matches": ["https://botcake.io/*"]
    }
  ]
}